# ──────────────────────────────────────────────
# SERVIDOR
# ──────────────────────────────────────────────
PORT=3001
RAILWAY_PUBLIC_DOMAIN=             # Se rellena automático en Railway

# ──────────────────────────────────────────────
# BASE DE DATOS (PostgreSQL)
# En Railway: agregar plugin PostgreSQL → se inyecta automáticamente
# En local: copiar DATABASE_URL desde el panel de Railway
# ──────────────────────────────────────────────
DATABASE_URL=                      # postgresql://user:password@host:5432/dbname

# ──────────────────────────────────────────────
# TELEGRAM
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                  # ID del grupo (negativo: -1001234567890)

# ──────────────────────────────────────────────
# WHATSAPP (asesores)
# ──────────────────────────────────────────────
WHATSAPP_EDUARDO=17869167339
WHATSAPP_JORGE=17865809908
WHATSAPP_PRINCIPAL=17869167339

# ──────────────────────────────────────────────
# META / FACEBOOK ADS
# ──────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=                 # Token de larga duración (60 días)
META_AD_ACCOUNT_ID=act_            # Formato: act_XXXXXXXXX
META_PIXEL_ID=
META_PAGE_ID=
META_WEBHOOK_TOKEN=                # Token secreto para verificar webhooks

# ──────────────────────────────────────────────
# VAPI (llamadas telefónicas con IA)
# ──────────────────────────────────────────────
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=

# ──────────────────────────────────────────────
# ANTHROPIC (Claude - análisis IA)
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────
# OPENAI (imágenes DALL-E)
# ──────────────────────────────────────────────
OPENAI_API_KEY=

# ──────────────────────────────────────────────
# REGLAS DE NEGOCIO (límites financieros)
# ──────────────────────────────────────────────
PRESUPUESTO_MAX_DIA=30             # Máximo diario en Meta Ads (USD)
LIMITE_ESCALAR_SOLO=10             # Escala automática sin consultar hasta este monto
LIMITE_GASTO_SIN_LEAD=4            # Pausa campaña si gasta esto sin generar leads
VAPI_DELAY_MINUTOS=5               # Minutos de espera antes de llamar al lead

# ──────────────────────────────────────────────
# TWILIO — WhatsApp automático (opcional)
# Sin esto las notificaciones van solo a Telegram
# Consigue cuenta en twilio.com → Messaging → WhatsApp
# ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=                # ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=                 # Token secreto de Twilio
TWILIO_WHATSAPP_FROM=              # whatsapp:+14155238886

# ──────────────────────────────────────────────
# HOTMART — Productos digitales (opcional)
# Consigue credenciales en developers.hotmart.com
# ──────────────────────────────────────────────
HOTMART_CLIENT_ID=                 # Client ID de tu app en Hotmart
HOTMART_CLIENT_SECRET=             # Client Secret de tu app en Hotmart
HOTMART_ENV=production             # "sandbox" para pruebas, "production" para real

# ──────────────────────────────────────────────
# STRIPE — Cobros de productos digitales
# Consigue las claves en dashboard.stripe.com
# ──────────────────────────────────────────────
STRIPE_SECRET_KEY=                 # sk_live_... (o sk_test_... para pruebas)
STRIPE_WEBHOOK_SECRET=             # whsec_... (desde Stripe → Webhooks → Signing secret)
                                   # URL del webhook: https://tu-dominio.railway.app/stripe/webhook
                                   # Evento a escuchar: checkout.session.completed

# ──────────────────────────────────────────────
# RESEND — Entrega de productos por email
# Consigue API key en resend.com (gratis hasta 3,000 emails/mes)
# ──────────────────────────────────────────────
RESEND_API_KEY=                    # re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=                        # tu@dominio.com (debe estar verificado en Resend)
EMAIL_FROM_NAME=Nexus Labs          # Nombre que aparece en el email

# ──────────────────────────────────────────────
# SEGURIDAD
# ──────────────────────────────────────────────
DASHBOARD_SECRET=                  # Contraseña para endpoints de admin
